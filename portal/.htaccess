RewriteEngine On

# Gestion générique des schémas Pitgun
# /schemas/<type>/<version>  →  /schemas/<type>/<version>.json

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Capture:
#   1 = type de schéma (analysis-manifest, pipeline-manifest, bundle…)
#   2 = version (v1, v2…)
RewriteRule ^schemas/([^/]+)/([^/]+)$ schemas/$1/$2.json [L]