{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pitgun.io/schemas/pipeline-manifest/v1",
  "title": "Pitgun Pipeline Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["manifest_version", "source", "processors", "sink"],
  "properties": {
    "manifest_version": {
      "type": "integer",
      "enum": [1]
    },

    "name": {
      "type": "string",
      "description": "Optional human-readable pipeline name"
    },

    "description": {
      "type": "string",
      "description": "Optional description of the pipeline"
    },

    "source": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": true,
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "udp",
            "tcp",
            "file",
            "stdin",
            "kafka",
            "websocket",
            "other"
          ]
        }
      }
    },

    "processors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["type"],
        "additionalProperties": true,
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "channel_filter",
              "scale",
              "stats",
              "map",
              "throttle",
              "other"
            ]
          },
          "id": {
            "type": "string",
            "description": "Optional processor identifier"
          }
        }
      }
    },

    "sink": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": true,
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "console",
            "file",
            "udp",
            "tcp",
            "kafka",
            "websocket",
            "other"
          ]
        }
      }
    }
  }
}